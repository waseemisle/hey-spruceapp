[debug] [2026-03-20T20:07:40.222Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/groundopss/rulesets {"name":"projects/groundopss/rulesets/dca035c3-9d70-4884-945a-73f051a51d5a","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function isSignedIn() { return request.auth != null }\n    function isAdmin() {\n      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));\n    }\n\n    // Default: deny everything\n    match /{document=**} { allow read, write: if false }\n\n    // Admin users - admins can read/write; users can read their own doc\n    match /adminUsers/{userId} {\n      allow read: if isSignedIn() && (isAdmin() || userId == request.auth.uid);\n      allow write: if isSignedIn() && isAdmin();\n    }\n\n    // Clients - admins full access; clients read/write own doc\n    match /clients/{clientId} {\n      allow read: if isSignedIn() && (isAdmin() || clientId == request.auth.uid);\n      allow write: if isSignedIn() && (isAdmin() || clientId == request.auth.uid);\n    }\n\n    // Subcontractors - admins full access; subcontractors read/write own doc; clients can read approved\n    match /subcontractors/{subcontractorId} {\n      allow read: if isSignedIn() && (isAdmin() || subcontractorId == request.auth.uid || resource.data.status == 'approved');\n      allow write: if isSignedIn() && (isAdmin() || subcontractorId == request.auth.uid);\n    }\n\n    // Work Orders - admins full access; clients/subcontractors read their own or company's; clients update their company's\n    match /workOrders/{workOrderId} {\n      allow read: if isSignedIn() && (\n        isAdmin() ||\n        resource.data.clientId == request.auth.uid ||\n        resource.data.assignedSubcontractor == request.auth.uid ||\n        (resource.data.biddingSubcontractors != null && request.auth.uid in resource.data.biddingSubcontractors) ||\n        (resource.data.companyId != null &&\n         exists(/databases/$(database)/documents/clients/$(request.auth.uid)) &&\n         get(/databases/$(database)/documents/clients/$(request.auth.uid)).data.companyId == resource.data.companyId)\n      );\n      allow create: if isSignedIn() && (isAdmin() || request.resource.data.clientId == request.auth.uid);\n      allow delete: if isSignedIn() && isAdmin();\n      allow update: if isSignedIn() && (\n        isAdmin() ||\n        resource.data.clientId == request.auth.uid ||\n        (resource.data.companyId != null &&\n         exists(/databases/$(database)/documents/clients/$(request.auth.uid)) &&\n         get(/databases/$(database)/documents/clients/$(request.auth.uid)).data.companyId == resource.data.companyId)\n      );\n    }\n\n    // Invoices - admins full access; clients read their own\n    match /invoices/{invoiceId} {\n      allow read: if isSignedIn() && (isAdmin() || resource.data.clientId == request.auth.uid);\n      allow write: if isSignedIn() && isAdmin();\n    }\n\n    // Quotes - admins full access; subcontractors read/write their own\n    match /quotes/{quoteId} {\n      allow read: if isSignedIn() && (\n        isAdmin() ||\n        resource.data.subcontractorId == request.auth.uid ||\n        resource.data.clientId == request.auth.uid\n      );\n      allow create: if isSignedIn() && (isAdmin() || request.resource.data.subcontractorId == request.auth.uid);\n      allow update, delete: if isSignedIn() && (isAdmin() || resource.data.subcontractorId == request.auth.uid);\n    }\n\n    // Companies / Subsidiaries - admins full; clients read their associated company\n    match /companies/{companyId} {\n      allow read: if isSignedIn() && (\n        isAdmin() ||\n        resource.data.clientId == request.auth.uid ||\n        (exists(/databases/$(database)/documents/clients/$(request.auth.uid)) &&\n         get(/databases/$(database)/documents/clients/$(request.auth.uid)).data.companyId == companyId)\n      );\n      allow write: if isSignedIn() && isAdmin();\n    }\n\n    match /subsidiaries/{subsidiaryId} {\n      allow read: if isSignedIn() && (isAdmin() || resource.data.clientId == request.auth.uid);\n      allow create: if isSignedIn() && (isAdmin() || request.resource.data.clientId == request.auth.uid);\n      allow update, delete: if isSignedIn() && (isAdmin() || resource.data.clientId == request.auth.uid);\n    }\n\n    // Locations - admins full; clients read their own or by company\n    match /locations/{locationId} {\n      allow read: if isSignedIn() && (\n        isAdmin() ||\n        resource.data.clientId == request.auth.uid ||\n        (resource.data.companyId != null &&\n         exists(/databases/$(database)/documents/clients/$(request.auth.uid)) &&\n         get(/databases/$(database)/documents/clients/$(request.auth.uid)).data.companyId == resource.data.companyId)\n      );\n      allow create: if isSignedIn() && (\n        isAdmin() || (\n          request.resource.data.clientId == request.auth.uid &&\n          request.resource.data.subsidiaryId is string &&\n          request.resource.data.subsidiaryId.size() > 0 &&\n          exists(/databases/$(database)/documents/subsidiaries/$(request.resource.data.subsidiaryId)) &&\n          get(/databases/$(database)/documents/subsidiaries/$(request.resource.data.subsidiaryId)).data.clientId == request.auth.uid\n        )\n      );\n      allow update, delete: if isSignedIn() && (isAdmin() || resource.data.clientId == request.auth.uid);\n    }\n\n    // Categories - admins write; all signed-in users read\n    match /categories/{categoryId} {\n      allow read: if isSignedIn();\n      allow write: if isSignedIn() && isAdmin();\n    }\n\n    // Recurring Work Orders - admins full; clients read their own or by assigned location\n    match /recurringWorkOrders/{workOrderId} {\n      allow read: if isSignedIn() && (\n        isAdmin() ||\n        resource.data.clientId == request.auth.uid ||\n        (resource.data.locationId != null &&\n         exists(/databases/$(database)/documents/clients/$(request.auth.uid)) &&\n         resource.data.locationId in get(/databases/$(database)/documents/clients/$(request.auth.uid)).data.assignedLocations)\n      );\n      allow write: if isSignedIn() && isAdmin();\n    }\n\n    // Recurring Work Order Executions - admins full; clients read their own\n    match /recurringWorkOrderExecutions/{executionId} {\n      allow read: if isSignedIn() && (isAdmin() || resource.data.recurringWorkOrderId != null);\n      allow write: if isSignedIn() && isAdmin();\n    }\n\n    // Maintenance Requests - admins full; clients can read all (requests may lack clientId)\n    match /maint_requests/{requestId} {\n      allow read: if isSignedIn() && (\n        isAdmin() ||\n        resource.data.clientId == request.auth.uid ||\n        exists(/databases/$(database)/documents/clients/$(request.auth.uid))\n      );\n      allow write: if isSignedIn() && isAdmin();\n    }\n\n    // Assets - admins full; all signed-in users read\n    match /assets/{assetId} {\n      allow read: if isSignedIn() && isAdmin();\n      allow write: if isSignedIn() && isAdmin();\n    }\n\n    // RFPs - admins full access\n    match /rfps/{rfpId} {\n      allow read: if isSignedIn() && isAdmin();\n      allow write: if isSignedIn() && isAdmin();\n    }\n\n    // Assigned Jobs - admins full; subcontractors read their own\n    match /assignedJobs/{jobId} {\n      allow read: if isSignedIn() && (isAdmin() || resource.data.subcontractorId == request.auth.uid);\n      allow write: if isSignedIn() && isAdmin();\n    }\n\n    // Bidding Work Orders - admins full; subcontractors read\n    match /biddingWorkOrders/{biddingId} {\n      allow read: if isSignedIn() && (isAdmin() || resource.data.subcontractorId == request.auth.uid);\n      allow write: if isSignedIn() && isAdmin();\n    }\n\n    // Location Mappings - admin only\n    match /locationMappings/{mappingId} {\n      allow read, write: if isSignedIn() && isAdmin();\n    }\n\n    // Email logs - admin only\n    match /emailLogs/{logId} {\n      allow read, write: if isSignedIn() && isAdmin();\n    }\n\n    // Client Charges (transaction history for manual/subscription charges)\n    // Admins can read/write; clients can read their own charges\n    match /clientCharges/{chargeId} {\n      allow read: if isSignedIn() && (isAdmin() || resource.data.clientId == request.auth.uid);\n      allow create: if true; // Allow server-side writes via API routes\n      allow update, delete: if isSignedIn() && isAdmin();\n    }\n\n    // Notifications - any signed-in user can create; users can read/update their own; admins full access\n    match /notifications/{notificationId} {\n      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);\n      allow create: if isSignedIn();\n      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);\n      allow delete: if isSignedIn() && isAdmin();\n    }\n\n    // API Tokens - admin only\n    match /api_tokens/{tokenId} {\n      allow read, write: if isSignedIn() && isAdmin();\n    }\n\n    // Scheduled Invoices - admin only\n    match /scheduled_invoices/{invoiceId} {\n      allow read, write: if isSignedIn() && isAdmin();\n    }\n\n    // Users (generic user profiles) - admin only\n    match /users/{userId} {\n      allow read: if isSignedIn() && (isAdmin() || userId == request.auth.uid);\n      allow write: if isSignedIn() && isAdmin();\n    }\n\n    // Work Order Notes - admins full; involved parties can read their own\n    match /workOrderNotes/{noteId} {\n      allow read: if isSignedIn() && (\n        isAdmin() ||\n        resource.data.clientId == request.auth.uid ||\n        resource.data.subcontractorId == request.auth.uid\n      );\n      allow create: if isSignedIn();\n      allow update, delete: if isSignedIn() && isAdmin();\n    }\n\n    // Ticket ID counters — admin only (API uses sync admin account)\n    match /counters/{counterId} {\n      allow read, write: if isSignedIn() && isAdmin();\n    }\n\n    // Support tickets — admins full; clients/subs read own tickets only\n    match /supportTickets/{ticketId} {\n      function supportTicketRead() {\n        return isAdmin() ||\n          resource.data.submittedBy == request.auth.uid ||\n          resource.data.clientId == request.auth.uid ||\n          resource.data.subcontractorId == request.auth.uid;\n      }\n      allow read: if isSignedIn() && supportTicketRead();\n      allow create: if isSignedIn() && isAdmin();\n      allow update, delete: if isSignedIn() && isAdmin();\n\n      match /comments/{commentId} {\n        function supportParent() {\n          return get(/databases/$(database)/documents/supportTickets/$(ticketId)).data;\n        }\n        allow read: if isSignedIn() && (\n          isAdmin() ||\n          (\n            (supportParent().submittedBy == request.auth.uid ||\n             supportParent().clientId == request.auth.uid ||\n             supportParent().subcontractorId == request.auth.uid) &&\n            resource.data.isInternal != true\n          )\n        );\n        allow create, update, delete: if isSignedIn() && isAdmin();\n      }\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-03-20T20:07:39.404511Z","metadata":{"services":["cloud.firestore"]}}

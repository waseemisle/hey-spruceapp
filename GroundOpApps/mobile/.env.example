# Canonical mobile env. Populated automatically via scripts/pull-vercel-env.sh.
# Server-only secrets (STRIPE_SECRET_KEY, MAILGUN_API_KEY, CRON_SECRET, SUPABASE_SERVICE_ROLE_KEY,
# CLOUDINARY_API_SECRET, SENDBLUE/TWILIO keys, FIREBASE_SYNC_*, etc.) MUST NOT appear here.

# Shared Firebase project: groundopss  (same as web, same as Android, same as iOS)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=groundopss
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Cloud Functions base URL (maint-requests lives here to bypass Vercel 4.5MB limit)
EXPO_PUBLIC_FIREBASE_FUNCTIONS_URL=https://us-central1-groundopss.cloudfunctions.net

# Stripe (same Stripe account as web)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Cloudinary (same cloud + preset as web)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=duo4kzgx4
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=WebAppUpload

# Backend (Vercel Next.js API)
EXPO_PUBLIC_APP_URL=https://groundopscos.vercel.app
EXPO_PUBLIC_APP_ENV=production

# Google Maps (if enabled)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Copy to scripts/e2e-secrets.env (gitignored) and fill values, or add the same keys to .env.local.
# The matrix script loads .env.local first, then scripts/e2e-secrets.env (values only apply if unset/empty).
# Then: npm run e2e:work-order-matrix

E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
E2E_CLIENT_EMAIL=mperasso1@icloud.com
E2E_CLIENT_PASSWORD=
E2E_SUB_EMAIL=waseemisle@gmail.com
E2E_SUB_PASSWORD=

# Optional — defaults match your sandbox
# E2E_BASE_URL=https://groundopscos.vercel.app
# E2E_CLIENT_UID=8mylICiCy8Oq5cR89DhFH5IgEUi1
# E2E_COMPANY_ID=nffggNElicRzjFOaVfHF
# E2E_LOCATION_ID=y5NircRoMX77Luf4Uhxg
# E2E_SUB_CONTRACTOR_DOC_ID=xcBZH6MlsbSRlwH3J1GmoOiUKWJ3

# Quote line totals (default labor 100 + material 50 = 150). Set E2E_QUOTE_TOTAL to override (single labor line).
# E2E_QUOTE_TOTAL=150
#
# Fixed Auto-Charge Plan: to verify auto-pay after "Generate & Send Invoice", set the test client's
# subscription amount (admin → client → Fixed Auto-Charge Plan Amount) and run:
#   E2E_TEST_AUTO_CHARGE=1 E2E_CLIENT_SUBSCRIPTION_AMOUNT=299.00 npm run e2e:work-order-matrix
# (Client must have active subscription + default payment method in Stripe test mode.)

# After each quote-flow WO reaches pending_invoice, click "Generate & Send Invoice" on admin list (default on).
# E2E_SKIP_INVOICE_STEP=1

# Extra scenario: client WO → approve → manual assign on WO detail (no bidding). Requires estimate budget on create.
# E2E_INCLUDE_MANUAL_ASSIGN=1

# If 1, browser console errors do not fail the run (still logged).
# E2E_ALLOW_BROWSER_CONSOLE_ERRORS=1

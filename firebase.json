{
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/maint-requests",
        "function": "maintRequests"
      },
      {
        "source": "/api/maint-requests/**",
        "function": "maintRequests"
      }
    ]
  }
}

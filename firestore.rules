rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null }
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    // Default: deny everything
    match /{document=**} { allow read, write: if false }

    // Admin users - admins can read/write; users can read their own doc
    match /adminUsers/{userId} {
      allow read: if isSignedIn() && (isAdmin() || userId == request.auth.uid);
      allow write: if isSignedIn() && isAdmin();
    }

    // Clients - admins full access; clients read/write own doc
    match /clients/{clientId} {
      allow read: if isSignedIn() && (isAdmin() || clientId == request.auth.uid);
      allow write: if isSignedIn() && (isAdmin() || clientId == request.auth.uid);
    }

    // Subcontractors - admins full access; subcontractors read/write own doc; clients can read approved
    match /subcontractors/{subcontractorId} {
      allow read: if isSignedIn() && (isAdmin() || subcontractorId == request.auth.uid || resource.data.status == 'approved');
      allow write: if isSignedIn() && (isAdmin() || subcontractorId == request.auth.uid);
    }

    // Work Orders - admins full access; clients/subcontractors read their own or company's; clients update their company's
    match /workOrders/{workOrderId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.clientId == request.auth.uid ||
        resource.data.assignedSubcontractor == request.auth.uid ||
        resource.data.assignedTo == request.auth.uid ||
        (resource.data.biddingSubcontractors != null && request.auth.uid in resource.data.biddingSubcontractors) ||
        (resource.data.companyId != null &&
         exists(/databases/$(database)/documents/clients/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/clients/$(request.auth.uid)).data.companyId == resource.data.companyId)
      );
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.clientId == request.auth.uid);
      allow delete: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && (
        isAdmin() ||
        resource.data.clientId == request.auth.uid ||
        (resource.data.companyId != null &&
         exists(/databases/$(database)/documents/clients/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/clients/$(request.auth.uid)).data.companyId == resource.data.companyId) ||
        (
          resource.data.biddingSubcontractors != null &&
          request.auth.uid in resource.data.biddingSubcontractors &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'status', 'quoteReceivedAt', 'updatedAt', 'timeline', 'systemInformation'
          ]) &&
          request.resource.data.status == 'quotes_received'
        ) ||
        (
          (
            resource.data.assignedSubcontractor == request.auth.uid ||
            resource.data.assignedTo == request.auth.uid
          ) &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'status',
            'scheduledServiceDate',
            'scheduledServiceTime',
            'scheduledServiceTimeEnd',
            'completedAt',
            'completionDetails',
            'completionNotes',
            'completionImages',
            'updatedAt',
            'timeline',
            'systemInformation'
          ]) &&
          request.resource.data.status in [
            'accepted_by_subcontractor',
            'rejected_by_subcontractor',
            'pending_invoice',
            'completed'
          ]
        )
      );
    }

    // Invoices - admins full access; clients read their own
    match /invoices/{invoiceId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.clientId == request.auth.uid);
      allow write: if isSignedIn() && isAdmin();
    }

    // Quotes - admins full access; subcontractors read/write their own
    match /quotes/{quoteId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.subcontractorId == request.auth.uid ||
        resource.data.clientId == request.auth.uid
      );
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.subcontractorId == request.auth.uid);
      allow update: if isSignedIn() && (
        isAdmin() ||
        resource.data.subcontractorId == request.auth.uid ||
        (
          // Client may only accept/reject their own quote with audit fields.
          resource.data.clientId == request.auth.uid &&
          request.resource.data.clientId == resource.data.clientId &&
          request.resource.data.subcontractorId == resource.data.subcontractorId &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'status',
            'acceptedAt',
            'rejectedAt',
            'rejectionReason',
            'timeline',
            'systemInformation',
            'updatedAt'
          ]) &&
          request.resource.data.status in ['sent_to_client', 'accepted', 'rejected']
        )
      );
      allow delete: if isSignedIn() && (isAdmin() || resource.data.subcontractorId == request.auth.uid);
    }

    // Companies / Subsidiaries - admins full; clients read their associated company
    match /companies/{companyId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.clientId == request.auth.uid ||
        (exists(/databases/$(database)/documents/clients/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/clients/$(request.auth.uid)).data.companyId == companyId)
      );
      allow write: if isSignedIn() && isAdmin();
    }

    match /subsidiaries/{subsidiaryId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.clientId == request.auth.uid);
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.clientId == request.auth.uid);
      allow update, delete: if isSignedIn() && (isAdmin() || resource.data.clientId == request.auth.uid);
    }

    // Locations - admins full; clients read their own or by company
    match /locations/{locationId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.clientId == request.auth.uid ||
        (resource.data.companyId != null &&
         exists(/databases/$(database)/documents/clients/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/clients/$(request.auth.uid)).data.companyId == resource.data.companyId)
      );
      allow create: if isSignedIn() && (
        isAdmin() || (
          request.resource.data.clientId == request.auth.uid &&
          request.resource.data.subsidiaryId is string &&
          request.resource.data.subsidiaryId.size() > 0 &&
          exists(/databases/$(database)/documents/subsidiaries/$(request.resource.data.subsidiaryId)) &&
          get(/databases/$(database)/documents/subsidiaries/$(request.resource.data.subsidiaryId)).data.clientId == request.auth.uid
        )
      );
      allow update, delete: if isSignedIn() && (isAdmin() || resource.data.clientId == request.auth.uid);
    }

    // Categories - admins write; anyone can read (needed for registration forms)
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin();
    }

    // Recurring Work Orders - admins full; clients read their own or by assigned location;
    // clients with the createRecurringWorkOrders permission can create + update + delete their own.
    match /recurringWorkOrders/{workOrderId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.clientId == request.auth.uid ||
        (resource.data.locationId != null &&
         exists(/databases/$(database)/documents/clients/$(request.auth.uid)) &&
         resource.data.locationId in get(/databases/$(database)/documents/clients/$(request.auth.uid)).data.assignedLocations)
      );
      // Client may create a recurring WO that they own. The clientId on the new doc must
      // equal their auth uid — they can't create one on behalf of another client.
      allow create: if isSignedIn() && (
        isAdmin() ||
        request.resource.data.clientId == request.auth.uid
      );
      // Client may update / delete only the recurring WOs they own. Admin retains full access.
      allow update, delete: if isSignedIn() && (
        isAdmin() ||
        resource.data.clientId == request.auth.uid
      );
    }

    // Recurring Work Order Executions - admins full; clients read their own
    match /recurringWorkOrderExecutions/{executionId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.recurringWorkOrderId != null);
      allow write: if isSignedIn() && isAdmin();
    }

    // Maintenance Requests - admins full; clients can read all (requests may lack clientId)
    match /maint_requests/{requestId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.clientId == request.auth.uid ||
        exists(/databases/$(database)/documents/clients/$(request.auth.uid))
      );
      allow write: if isSignedIn() && isAdmin();
    }

    // Assets - admins full; all signed-in users read
    match /assets/{assetId} {
      allow read: if isSignedIn() && isAdmin();
      allow write: if isSignedIn() && isAdmin();
    }

    // RFPs - admins full access
    match /rfps/{rfpId} {
      allow read: if isSignedIn() && isAdmin();
      allow write: if isSignedIn() && isAdmin();
    }

    // Assigned Jobs - admins full; subcontractors read their own; clients can create for their own work orders
    match /assignedJobs/{jobId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.subcontractorId == request.auth.uid);
      allow create: if isSignedIn() && (
        isAdmin() ||
        (
          request.resource.data.workOrderId is string &&
          get(/databases/$(database)/documents/workOrders/$(request.resource.data.workOrderId)).data.clientId == request.auth.uid
        )
      );
      allow delete: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          resource.data.subcontractorId == request.auth.uid &&
          request.resource.data.subcontractorId == resource.data.subcontractorId &&
          request.resource.data.workOrderId == resource.data.workOrderId &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'status',
            'acceptedAt',
            'rejectedAt',
            'rejectionReason',
            'scheduledServiceDate',
            'scheduledServiceTime',
            'scheduledServiceTimeEnd'
          ]) &&
          request.resource.data.status in ['accepted', 'rejected']
        )
      );
    }

    // Bidding Work Orders - admins full; clients can create for their own work orders or same-company work orders; subcontractors read
    match /biddingWorkOrders/{biddingId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.subcontractorId == request.auth.uid ||
        resource.data.clientId == request.auth.uid ||
        (resource.data.companyId != null &&
         exists(/databases/$(database)/documents/clients/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/clients/$(request.auth.uid)).data.companyId == resource.data.companyId)
      );
      allow create: if isSignedIn() && (
        isAdmin() ||
        request.resource.data.clientId == request.auth.uid ||
        (request.resource.data.companyId != null &&
         exists(/databases/$(database)/documents/clients/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/clients/$(request.auth.uid)).data.companyId == request.resource.data.companyId)
      );
      allow delete: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          resource.data.subcontractorId == request.auth.uid &&
          request.resource.data.subcontractorId == resource.data.subcontractorId &&
          request.resource.data.workOrderId == resource.data.workOrderId &&
          request.resource.data.clientId == resource.data.clientId &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'status', 'quotedAt', 'updatedAt'
          ]) &&
          request.resource.data.status in ['pending', 'quoted', 'declined']
        )
      );
    }

    // Cron Job Runs — admin only (cron monitoring page)
    match /cronJobRuns/{runId} {
      allow read, write: if isSignedIn() && isAdmin();
    }

    // Location Mappings - admin only
    match /locationMappings/{mappingId} {
      allow read, write: if isSignedIn() && isAdmin();
    }

    // Email logs - admin only
    match /emailLogs/{logId} {
      allow read, write: if isSignedIn() && isAdmin();
    }

    // Client Charges (transaction history for manual/subscription charges)
    // Admins can read/write; clients can read their own charges
    match /clientCharges/{chargeId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.clientId == request.auth.uid);
      allow create: if true; // Allow server-side writes via API routes
      allow update, delete: if isSignedIn() && isAdmin();
    }

    // Notifications - any signed-in user can create; users can read/update their own; admins full access
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isSignedIn() && isAdmin();
    }

    // API Tokens - admin only
    match /api_tokens/{tokenId} {
      allow read, write: if isSignedIn() && isAdmin();
    }

    // Scheduled Invoices - admin only
    match /scheduled_invoices/{invoiceId} {
      allow read, write: if isSignedIn() && isAdmin();
    }

    // Vendor Payments - admin write; subcontractor read own; clients no access
    match /vendorPayments/{vendorPaymentId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.subcontractorId == request.auth.uid);
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    // Users (generic user profiles) - admin full; users can create/read their own doc
    match /users/{userId} {
      allow read: if isSignedIn() && (isAdmin() || userId == request.auth.uid);
      allow create: if isSignedIn() && userId == request.auth.uid;
      allow update, delete: if isSignedIn() && isAdmin();
    }

    // Work Order Notes - admins full; involved parties can read their own
    match /workOrderNotes/{noteId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.clientId == request.auth.uid ||
        resource.data.subcontractorId == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && isAdmin();
    }

    // Ticket ID counters — admin only (API uses sync admin account)
    match /counters/{counterId} {
      allow read, write: if isSignedIn() && isAdmin();
    }

    // Chats — admins full; participants can read/write their own chats
    match /chats/{chatId} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && (isAdmin() || request.auth.uid in request.resource.data.participants);
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.participants);
      allow delete: if isSignedIn() && isAdmin();

      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          isAdmin() ||
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
        );
        allow create: if isSignedIn() && (
          isAdmin() ||
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
        );
        allow update, delete: if isSignedIn() && isAdmin();
      }
    }

    // Support tickets — admins full; clients/subs read own tickets only
    match /supportTickets/{ticketId} {
      function supportTicketRead() {
        return isAdmin() ||
          resource.data.submittedBy == request.auth.uid ||
          resource.data.clientId == request.auth.uid ||
          resource.data.subcontractorId == request.auth.uid;
      }
      allow read: if isSignedIn() && supportTicketRead();
      allow create: if isSignedIn() && isAdmin();
      allow update, delete: if isSignedIn() && isAdmin();

      match /comments/{commentId} {
        function supportParent() {
          return get(/databases/$(database)/documents/supportTickets/$(ticketId)).data;
        }
        allow read: if isSignedIn() && (
          isAdmin() ||
          (
            (supportParent().submittedBy == request.auth.uid ||
             supportParent().clientId == request.auth.uid ||
             supportParent().subcontractorId == request.auth.uid) &&
            resource.data.isInternal != true
          )
        );
        allow create, update, delete: if isSignedIn() && isAdmin();
      }
    }
  }
}
